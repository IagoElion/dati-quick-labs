{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AssumePartnerCentralRole",
            "Effect": "Allow",
            "Action": "sts:AssumeRole",
            "Resource": "arn:aws:iam::107028717321:role/PartnerCentralMCPRole",
            "Condition": {
                "StringEquals": {
                    "sts:ExternalId": "partner-central-mcp-proxy"
                }
            }
        },
        {
            "Sid": "SecretsManagerRead",
            "Effect": "Allow",
            "Action": [
                "secretsmanager:GetSecretValue"
            ],
            "Resource": "arn:aws:secretsmanager:us-east-1:601804669442:secret:mcp-partner-central/oauth-credentials-*"
        },
        {
            "Sid": "CloudWatchLogs",
            "Effect": "Allow",
            "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents"
            ],
            "Resource": "arn:aws:logs:us-east-1:601804669442:*"
        }
    ]
}
