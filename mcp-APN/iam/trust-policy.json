{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowLambdaProxyCrossAccount",
            "Effect": "Allow",
            "Principal": {
                "AWS": "arn:aws:iam::601804669442:root"
            },
            "Action": "sts:AssumeRole",
            "Condition": {
                "StringEquals": {
                    "sts:ExternalId": "partner-central-mcp-proxy"
                }
            }
        }
    ]
}
