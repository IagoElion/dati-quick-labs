# Circleback OAuth (obter em https://circleback.ai/settings/developers)
CIRCLEBACK_CLIENT_ID=seu_client_id_aqui
CIRCLEBACK_CLIENT_SECRET=seu_client_secret_aqui

# Redirect URI - será gerada automaticamente pelo serverless deploy
# Para dev local, use:
CIRCLEBACK_REDIRECT_URI=http://localhost:3000/oauth/callback

# DynamoDB Table (gerada pelo serverless)
TOKEN_TABLE=circleback-mcp-tokens-prod

# Environment
NODE_ENV=development
PORT=3000
AWS_REGION=us-east-1
